<!--
  Wheeled inverted pendulum (self-balancing robot) for the MuJoCo backend.

  This is a clean, contact-free articulated model used for (a) high-fidelity / visual
  simulation and (b) an independent cross-check of the analytic plant. Masses, inertias,
  COM offset and joint damping are overwritten at load time from `RobotParams`
  (see sim/mujoco_backend.py), so the MuJoCo plant matches the canonical model.

  Two DOFs: a prismatic `slide` (base x) and a hinge `pend_hinge` (body tilt about y).
  Two actuators map a single motor torque tau:  slide force = tau/r,  hinge torque = -tau.
  Contacts are disabled (contype/conaffinity = 0) so the dynamics are purely articulated.
-->
<mujoco model="segway">
  <option gravity="0 0 -9.81" timestep="0.001"/>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.5 0.6 0.7" rgb2="0.1 0.1 0.15"
             width="512" height="512"/>
    <texture name="grid" type="2d" builtin="checker" rgb1="0.2 0.25 0.3" rgb2="0.3 0.35 0.4"
             width="512" height="512"/>
    <material name="grid" texture="grid" texrepeat="8 8" reflectance="0.1"/>
    <material name="wheel" rgba="0.12 0.12 0.14 1"/>
    <material name="body" rgba="0.0 0.78 0.9 1"/>
  </asset>

  <worldbody>
    <light pos="0 0 4" dir="0 0 -1" diffuse="0.8 0.8 0.8"/>
    <geom name="floor" type="plane" pos="0 0 0" size="20 20 0.1" material="grid"
          contype="0" conaffinity="0"/>

    <body name="base" pos="0 0 0.1">
      <inertial pos="0 0 0" mass="1.864" diaginertia="0.02 0.02 0.02"/>
      <joint name="slide" type="slide" axis="1 0 0" damping="0.05"/>

      <!-- visual wheels -->
      <geom type="cylinder" size="0.1 0.025" pos="0 0.11 0" euler="90 0 0"
            material="wheel" contype="0" conaffinity="0"/>
      <geom type="cylinder" size="0.1 0.025" pos="0 -0.11 0" euler="90 0 0"
            material="wheel" contype="0" conaffinity="0"/>

      <body name="pendulum" pos="0 0 0">
        <inertial pos="0 0 0.4" mass="5.0" diaginertia="0.2 0.2 0.01"/>
        <joint name="pend_hinge" type="hinge" axis="0 1 0" damping="0.2"/>
        <geom type="capsule" fromto="0 0 0 0 0 0.5" size="0.035" material="body"
              contype="0" conaffinity="0"/>
        <geom type="box" pos="0 0 0.52" size="0.09 0.06 0.04" material="body"
              contype="0" conaffinity="0"/>
      </body>
    </body>
  </worldbody>

  <actuator>
    <general name="wheel_drive" joint="slide" gear="1" ctrllimited="true" ctrlrange="-2000 2000"/>
    <general name="reaction_torque" joint="pend_hinge" gear="1" ctrllimited="true" ctrlrange="-500 500"/>
  </actuator>

  <sensor>
    <jointpos joint="slide"/>
    <jointvel joint="slide"/>
    <jointpos joint="pend_hinge"/>
    <jointvel joint="pend_hinge"/>
  </sensor>
</mujoco>
