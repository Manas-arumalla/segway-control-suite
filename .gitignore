# Byte-compiled / optimized
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
build/
dist/
*.egg-info/
.eggs/
*.egg

# Virtual environments
.venv/
venv/
env/
.env

# Test / coverage / type-check caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
coverage.xml

# Benchmark outputs are regenerated (`make bench` / `make tune` / `run_nav.py`); curated copies
# live in assets/ and are embedded in the README. Keep only the directory placeholders.
benchmarks/results/*
!benchmarks/results/.gitkeep
benchmarks/nav_results/

# Trained RL models + training logs (regenerated via scripts/train_*.py)
*.zip
models/checkpoints/
models/nav_train_log/

# Rendered media scratch (curated finals live in assets/)
*.mp4
*.gif
!assets/**/*.gif
!assets/**/*.mp4
assets/gui_render.gif        # scratch balancing render produced by the desktop GUI
assets/gui_nav.gif           # scratch navigation render produced by the desktop GUI

# Docs build
site/

# OS / editor
.DS_Store
Thumbs.db
*.swp
.idea/

# NOTE: the legacy reference implementation in "Control GUI/" is intentionally
# committed as-is and never modified.
